---
import { getRelativeLocaleUrl } from "astro:i18n";
import IconMenuDeep from "@/assets/icons/IconMenuDeep.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconX from "@/assets/icons/IconX.svg";
import LinkButton from "./LinkButton.astro";
import { stripBase, stripLocale } from "@/utils/withBase";
import { useTranslations } from "@/i18n";
import config from "@/config";

const { site, features } = config;
const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const relativePath = stripBase(Astro.url.pathname);
const pathWithoutTrailingSlash =
  relativePath.endsWith("/") && relativePath !== "/"
    ? relativePath.slice(0, -1)
    : relativePath;
const currentPath = stripLocale(pathWithoutTrailingSlash, locale);

const isActive = (path: string) => {
  const cur = currentPath.split("/").filter(p => p.trim());
  const p = path.split("/").filter(p => p.trim());
  return currentPath === path || (path !== "" && cur[0] === p[0]);
};

const navLinks = [
  { label: "Home", path: "" },
  { label: "Blog", path: "posts" },
  { label: "About", path: "about" },
];
---

<a
  id="skip-to-content"
  href="#main-content"
  class="bg-background text-accent absolute inset-s-16 -top-full z-50 px-3 py-2 backdrop-blur-lg transition-all focus:top-4"
>
  {t.a11y.skipToContent}
</a>

<header class="app-layout">
  <div class="border-border flex items-center justify-between border-b py-4">
    <!-- Logo -->
    <a
      href={getRelativeLocaleUrl(locale, "")}
      class="text-lg font-semibold whitespace-nowrap shrink-0"
    >
      {site.title}
    </a>

    <!-- Desktop nav -->
    <div class="hidden sm:flex items-center gap-1">
      {navLinks.map(link => (
        <a
          href={getRelativeLocaleUrl(locale, link.path)}
          class:list={[
            "px-3 py-1.5 text-sm font-medium whitespace-nowrap rounded-md transition-colors",
            isActive(link.path)
              ? "text-accent bg-muted/50"
              : "text-muted-foreground hover:text-foreground hover:bg-muted/30",
          ]}
        >
          {link.label}
        </a>
      ))}
      <span class="w-px h-5 bg-border mx-1"></span>
      {
        features.search !== false && (
          <LinkButton
            href={getRelativeLocaleUrl(locale, "search")}
            class="size-9 flex items-center justify-center rounded-md text-muted-foreground hover:text-foreground hover:bg-muted/30"
            title={t.nav.search}
            aria-label={t.nav.search}
          >
            <IconSearch class="size-5" />
          </LinkButton>
        )
      }
      {
        features.lightAndDarkMode && (
          <button
            id="theme-btn"
            class="size-9 flex items-center justify-center rounded-md text-muted-foreground hover:text-foreground hover:bg-muted/30"
            title={t.a11y.toggleTheme}
            aria-label="auto"
            aria-live="polite"
          >
            <IconMoon class="size-5 block dark:hidden" />
            <IconSunHigh class="size-5 hidden dark:block" />
          </button>
        )
      }
    </div>

    <!-- Mobile menu button -->
    <button
      id="menu-btn"
      class="sm:hidden size-9 flex items-center justify-center rounded-md text-muted-foreground hover:text-foreground"
      aria-label={t.a11y.openMenu}
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <IconX id="close-icon" class="size-5 hidden" />
      <IconMenuDeep id="menu-icon" class="size-5" />
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="sm:hidden hidden border-border border-b pb-4"
  >
    <nav class="flex flex-col gap-1">
      {navLinks.map(link => (
        <a
          href={getRelativeLocaleUrl(locale, link.path)}
          class:list={[
            "px-4 py-2 text-sm font-medium whitespace-nowrap rounded-md",
            isActive(link.path)
              ? "text-accent bg-muted/50"
              : "text-muted-foreground hover:bg-muted/30",
          ]}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  function setupMenu() {
    const btn = document.querySelector<HTMLButtonElement>("#menu-btn");
    const menu = document.querySelector("#mobile-menu");
    const menuIcon = document.querySelector("#menu-icon");
    const closeIcon = document.querySelector("#close-icon");
    if (!btn || !menu || !menuIcon || !closeIcon) return;

    btn.addEventListener("click", () => {
      const open = btn.getAttribute("aria-expanded") === "true";
      btn.setAttribute("aria-expanded", open ? "false" : "true");
      menu.classList.toggle("hidden");
      menuIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");
    });
  }
  setupMenu();
  document.addEventListener("astro:after-swap", setupMenu);
</script>
