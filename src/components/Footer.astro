---
import type { HTMLAttributes } from "astro/types";
import { getRelativeLocaleUrl } from "astro:i18n";
import { useTranslations } from "@/i18n";

type Props = { noMarginTop?: boolean } & HTMLAttributes<"footer">;

const { noMarginTop = false, class: className, ...attrs } = Astro.props;
const t = useTranslations(Astro.currentLocale);
const currentYear = new Date().getFullYear();
const locale = Astro.currentLocale ?? "zh";

const footerLinks = [
  { label: "Academic", path: "academic" },
  { label: "Projects", path: "projects" },
  { label: "Links", path: "links" },
  { label: "Archives", path: "archives" },
  { label: "Search", path: "search" },
];
---

<footer class:list={["app-layout", { "mt-auto": !noMarginTop }, className]} {...attrs}>
  <div class="border-border flex flex-col items-center gap-3 border-t py-6 text-xs text-muted-foreground">
    <div class="flex flex-wrap justify-center gap-x-3 gap-y-1">
      {footerLinks.map(link => (
        <a
          href={getRelativeLocaleUrl(locale, link.path)}
          class="whitespace-nowrap hover:text-accent"
        >
          {link.label}
        </a>
      ))}
    </div>
    <div class="flex flex-wrap justify-center gap-x-3 gap-y-1">
      <span>&#169; {currentYear} {t.footer.copyright}</span>
      <a href="/terms" class="hover:text-accent">Site Policy</a>
      <a href="https://github.com/oohyees/oohyees.github.io" target="_blank" rel="noopener" class="hover:text-accent">GitHub</a>
      <a href="/rss.xml" class="hover:text-accent">RSS</a>
      <span>Powered by Astro</span>
    </div>
  </div>
</footer>
