---
type Props = {
  summary: string;
  open?: boolean;
};
const { summary, open = false } = Astro.props;
---

<details class="my-4 border border-border rounded-lg overflow-hidden" {open}>
  <summary
    class="cursor-pointer px-4 py-3 bg-muted/50 hover:bg-muted font-medium text-sm select-none"
  >
    {summary}
  </summary>
  <div class="px-4 py-3 text-sm">
    <slot />
  </div>
</details>
