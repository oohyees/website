---
type Props = {
  type?: "info" | "warning" | "error" | "tip" | "success";
  title?: string;
};

const { type = "info", title } = Astro.props;

const colors = {
  info: "border-blue-500 bg-blue-50 dark:bg-blue-950/30",
  warning: "border-amber-500 bg-amber-50 dark:bg-amber-950/30",
  error: "border-red-500 bg-red-50 dark:bg-red-950/30",
  tip: "border-emerald-500 bg-emerald-50 dark:bg-emerald-950/30",
  success: "border-green-500 bg-green-50 dark:bg-green-950/30",
};

const icons = {
  info: "i",
  warning: "!",
  error: "x",
  tip: "?",
  success: "✓",
};

const defaultTitles = {
  info: "信息",
  warning: "注意",
  error: "错误",
  tip: "提示",
  success: "完成",
};
---

<div
  class:list={[
    "my-6 rounded-lg border-l-4 p-4",
    colors[type],
  ]}
  role={type === "error" ? "alert" : "note"}
>
  <div class="flex items-center gap-2 mb-1">
    <span
      class:list={[
        "flex items-center justify-center size-5 rounded-full text-xs font-bold text-white",
        type === "info" && "bg-blue-500",
        type === "warning" && "bg-amber-500",
        type === "error" && "bg-red-500",
        type === "tip" && "bg-emerald-500",
        type === "success" && "bg-green-500",
      ]}
    >
      {icons[type]}
    </span>
    <span class="font-semibold text-sm">{title ?? defaultTitles[type]}</span>
  </div>
  <div class="text-sm text-muted-foreground">
    <slot />
  </div>
</div>
