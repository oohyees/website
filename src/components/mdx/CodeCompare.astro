---
type Props = {
  titleA?: string;
  titleB?: string;
};
const { titleA = "Before", titleB = "After" } = Astro.props;
const slots = Astro.slots;
---

<div class="my-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
  <div class="rounded-lg border border-border overflow-hidden">
    <div class="bg-muted/50 px-3 py-1.5 text-xs font-medium text-muted-foreground border-b border-border">
      {titleA}
    </div>
    <div class="text-xs [&_pre]:my-0 [&_pre]:rounded-none">
      <slot name="a" />
    </div>
  </div>
  <div class="rounded-lg border border-border overflow-hidden">
    <div class="bg-muted/50 px-3 py-1.5 text-xs font-medium text-muted-foreground border-b border-border">
      {titleB}
    </div>
    <div class="text-xs [&_pre]:my-0 [&_pre]:rounded-none">
      <slot name="b" />
    </div>
  </div>
</div>
