---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import { getPostUrl } from "@/utils/getPostPaths";
import config from "@/config";
import dayjs from "dayjs";

const locale = Astro.currentLocale ?? config.site.lang;
const posts = await getCollection("posts");
const publishedPosts = posts.filter(p => !p.data.draft);

const siteBirthday = dayjs("2026-05-27");
const daysOnline = dayjs().diff(siteBirthday, "day");
---

<Layout>
  <Header />
  <main id="main-content" class="app-layout">
    <!-- Hero: avatar + name + intro -->
    <section class="pt-10 pb-8">
      <div class="flex flex-col sm:flex-row items-center sm:items-start gap-5">
        <img
          src="https://github.com/oohyees.png"
          alt="avatar"
          class="size-20 rounded-full ring-1 ring-border shrink-0"
          width="80"
          height="80"
        />
        <div class="text-center sm:text-left">
          <h1 class="text-2xl font-bold">{config.site.author}</h1>
          <p class="mt-1 text-sm text-muted-foreground leading-relaxed max-w-md">
            这里是 oohyees 的个人网站。记录编程、技术和日常思考。
          </p>
          <div class="mt-2 flex justify-center sm:justify-start">
            <Socials />
          </div>
        </div>
      </div>
    </section>

    <hr class="border-border" />

    <!-- About -->
    <section class="py-8">
      <h2 class="text-lg font-semibold mb-3">About</h2>
      <p class="text-sm text-muted-foreground leading-relaxed">
        这里是 oohyees 的个人网站。记录编程、技术和日常思考。
      </p>
      <a
        href={getRelativeLocaleUrl(locale, "about")}
        class="inline-block mt-2 text-sm text-accent hover:underline"
      >
        了解更多 &rarr;
      </a>
    </section>

    <hr class="border-border" />

    <!-- Blog Categories -->
    <section class="py-8">
      <h2 class="text-lg font-semibold mb-4">Blog</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
        {
          [
            { label: "Research", path: "blog/research", desc: "学术研究" },
            { label: "Technical", path: "blog/tech", desc: "技术文章" },
            { label: "Daily Life", path: "blog/daily", desc: "日常随笔" },
            { label: "Journal", path: "blog/journal", desc: "月度归档" },
          ].map(cat => (
            <a
              href={getRelativeLocaleUrl(locale, cat.path)}
              class="rounded-lg border border-border px-4 py-3 text-center text-sm hover:border-accent hover:bg-muted/30 transition-colors"
            >
              <div class="font-medium">{cat.label}</div>
              <div class="text-xs text-muted-foreground mt-0.5">{cat.desc}</div>
            </a>
          ))
        }
      </div>
    </section>

    <hr class="border-border" />

    <!-- Stats + recent posts -->
    <section class="py-8">
      <h2 class="text-lg font-semibold mb-4">Statistics</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 text-center">
        <div class="rounded-lg border border-border px-3 py-3">
          <div class="text-xl font-bold text-accent">{daysOnline}</div>
          <div class="text-xs text-muted-foreground mt-0.5">Days Online</div>
        </div>
        <div class="rounded-lg border border-border px-3 py-3">
          <div class="text-xl font-bold text-accent">{publishedPosts.length}</div>
          <div class="text-xs text-muted-foreground mt-0.5">Posts</div>
        </div>
        <div class="rounded-lg border border-border px-3 py-3">
          <a
            href={getRelativeLocaleUrl(locale, "rss.xml")}
            class="text-xl font-bold text-accent hover:underline"
          >
            RSS
          </a>
          <div class="text-xs text-muted-foreground mt-0.5">Feed</div>
        </div>
      </div>

      <!-- Recent Posts -->
      {
        publishedPosts.length > 0 && (
          <div class="mt-8">
            <h3 class="text-base font-semibold mb-3">
              最近文章
              <a
                href={getRelativeLocaleUrl(locale, "posts")}
                class="ms-2 text-xs font-normal text-muted-foreground hover:text-accent"
              >
                全部 &rarr;
              </a>
            </h3>
            <ul class="space-y-0.5">
              {publishedPosts.slice(0, 5).map(post => (
                <li>
                  <a
                    href={getPostUrl(post.id, post.filePath, locale)}
                    class="flex items-baseline gap-2 text-sm text-muted-foreground hover:text-accent py-1"
                  >
                    <span class="text-xs opacity-50 tabular-nums shrink-0 w-24">
                      {dayjs(post.data.pubDatetime).format("YYYY-MM-DD")}
                    </span>
                    <span class="truncate">{post.data.title}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )
      }
    </section>
  </main>
  <Footer />
</Layout>
