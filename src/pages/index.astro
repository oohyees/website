---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { getPostSlug } from "@/utils/getPostPaths";
import { useTranslations } from "@/i18n";
import config from "@/config";
import dayjs from "dayjs";

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const posts = await getCollection("posts");
const publishedPosts = posts.filter(p => !p.data.draft);

let totalWords = 0;
for (const post of publishedPosts) {
  totalWords += post.data.words || 0;
}
const siteBirthday = dayjs("2026-05-27");
const daysOnline = dayjs().diff(siteBirthday, "day");
const lastUpdated = dayjs().format("YYYY年M月D日");
---

<Layout>
  <Header />
  <main id="main-content" class="app-layout">
    <!-- Personal Card -->
    <section class="border-border border-b pt-8 pb-8">
      <div class="flex flex-col sm:flex-row items-center sm:items-start gap-6">
        <img
          src="https://github.com/oohyees.png"
          alt="avatar"
          class="size-24 rounded-full ring-2 ring-border"
          width="96"
          height="96"
        />
        <div class="text-center sm:text-left">
          <h1 class="text-3xl font-bold">{config.site.author}</h1>
          <p class="mt-1 text-muted-foreground">China</p>
          <div class="mt-3">
            <Socials />
          </div>
        </div>
      </div>
    </section>

    <!-- About -->
    <section class="border-border border-b py-8">
      <h2 class="text-2xl font-semibold mb-4">About</h2>
      <p class="text-muted-foreground leading-relaxed">
        这里是 oohyeyes 的个人网站。记录编程、技术和日常思考。
      </p>
      <LinkButton
        href={getRelativeLocaleUrl(locale, "about")}
        class="mt-2 inline-flex items-center gap-1 text-sm hover:text-accent"
      >
        了解更多 <IconArrowRight class="inline-block size-4 rtl:-rotate-180" />
      </LinkButton>
    </section>

    <!-- Education -->
    <section class="border-border border-b py-8">
      <h2 class="text-2xl font-semibold mb-4">Education</h2>
      <div class="space-y-4">
        <div class="flex items-start gap-4">
          <div class="mt-1 size-3 rounded-full bg-accent shrink-0"></div>
          <div>
            <a href="#" class="font-medium hover:text-accent">学校名称</a>
            <p class="text-sm text-muted-foreground">专业 · 本科/硕士/博士</p>
            <p class="text-xs text-muted-foreground mt-0.5">Sep 2022 — Present</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="mt-1 size-3 rounded-full bg-accent/50 shrink-0"></div>
          <div>
            <a href="#" class="font-medium hover:text-accent">公司/实验室名称</a>
            <p class="text-sm text-muted-foreground">职位/角色</p>
            <p class="text-xs text-muted-foreground mt-0.5">Jul 2024 — Present</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Blog Categories -->
    <section class="border-border border-b py-8">
      <h2 class="text-2xl font-semibold mb-4">{t.nav.posts}</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        {
          [
            { label: "Research", path: "tags/research", desc: "研究" },
            { label: "Technical", path: "tags/tech", desc: "技术" },
            { label: "Daily Life", path: "tags/daily", desc: "日常" },
            { label: "Journal", path: "tags/journal", desc: "月记" },
          ].map(cat => (
            <a
              href={getRelativeLocaleUrl(locale, cat.path)}
              class="rounded-lg border border-border p-4 text-center hover:border-accent hover:bg-muted/30 transition-colors"
            >
              <div class="font-semibold">{cat.label}</div>
              <div class="text-xs text-muted-foreground mt-1">{cat.desc}</div>
            </a>
          ))
        }
      </div>
    </section>

    <!-- Statistics -->
    <section class="py-8">
      <h2 class="text-2xl font-semibold mb-4">Statistics</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 text-center">
        <div class="rounded-lg border border-border p-4">
          <div class="text-2xl font-bold text-accent">{daysOnline}</div>
          <div class="text-xs text-muted-foreground mt-1">Days Online</div>
        </div>
        <div class="rounded-lg border border-border p-4">
          <div class="text-2xl font-bold text-accent">{lastUpdated}</div>
          <div class="text-xs text-muted-foreground mt-1">Last Updated</div>
        </div>
        <div class="rounded-lg border border-border p-4">
          <div class="text-2xl font-bold text-accent">{totalWords.toLocaleString()}</div>
          <div class="text-xs text-muted-foreground mt-1">Total Words</div>
        </div>
        <div class="rounded-lg border border-border p-4">
          <div class="text-2xl font-bold text-accent">{publishedPosts.length}</div>
          <div class="text-xs text-muted-foreground mt-1">Total Posts</div>
        </div>
      </div>

      <!-- GitHub Heatmap -->
      <div class="mt-8 rounded-lg border border-border p-4 overflow-x-auto">
        <p class="text-sm text-muted-foreground mb-3 text-center">GitHub Contributions</p>
        <img
          src={`https://ghchart.rshah.org/oohyees`}
          alt="GitHub contribution chart"
          class="min-w-[700px] w-full"
          loading="lazy"
        />
        <p class="text-xs text-muted-foreground mt-2 text-center">
          contributions in the last year
        </p>
      </div>

      <!-- Recent Posts -->
      {
        publishedPosts.length > 0 && (
          <div class="mt-8">
            <h3 class="text-lg font-semibold mb-3">
              {t.home.recentPosts}
              <LinkButton
                href={getRelativeLocaleUrl(locale, "posts")}
                class="ms-2 text-sm font-normal hover:text-accent"
              >
                {t.home.allPosts} <IconArrowRight class="inline-block size-4 rtl:-rotate-180" />
              </LinkButton>
            </h3>
            <ul class="space-y-1">
              {publishedPosts.slice(0, 5).map(post => (
                <li>
                  <a
                    href={getRelativeLocaleUrl(locale, `posts/${getPostSlug(post.id, post.filePath)}`)}
                    class="text-muted-foreground hover:text-accent text-sm"
                  >
                    <span class="text-xs opacity-60 tabular-nums">
                      {dayjs(post.data.pubDatetime).format("YYYY-MM-DD")}
                    </span>
                    <span class="ms-2">{post.data.title}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )
      }

      <!-- RSS -->
      <div class="mt-6 text-center">
        <a
          href={getRelativeLocaleUrl(locale, "rss.xml")}
          class="inline-flex items-center gap-1 text-sm text-muted-foreground hover:text-accent"
        >
          <IconRss class="size-4" /> RSS Feed
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
